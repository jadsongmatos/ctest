{
  "name": "ctest",
  "version": "2.0.0",
  "description": "Gera arquivos .md com testes externos relevantes usando SBOM + Horsebox.",
  "main": "src/index.js",
  "bin": {
    "ctest": "./src/index.js"
  },
  "scripts": {
    "ctest": "node src/index.js",
    "test": "jest --coverage --silent",
    "lint": "eslint src/**/*.js tests/**/*.js",
    "lint:fix": "eslint src/**/*.js tests/**/*.js --fix",
    "lint:report": "eslint src/**/*.js tests/**/*.js -f json -o reports/eslint-report.json"
  },
  "keywords": [
    "sbom",
    "cyclonedx",
    "horsebox",
    "code-search",
    "dependency-analysis"
  ],
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@babel/parser": "^7.28.0",
    "@cyclonedx/cyclonedx-npm": "^4.2.0",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-standard": "^4.1.0",
    "jest": "^30.2.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/src_modules/"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  }
}
