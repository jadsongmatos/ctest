{
  "name": "ctest",
  "version": "1.0.0",
  "description": "Ctest is a command-line tool that analyzes npm projects.",
  "main": "src/index.js",
  "bin": {
    "ctest": "./src/index.js"
  },
  "scripts": {
    "test": "jest --coverage",
    "ctest": "node src/index.js",
    "jest-fn-to-sqlite": "node scripts/jest-fn-to-sqlite.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jadsongmatos/ctest.git"
  },
  "keywords": [
    "sbom",
    "cyclonedx",
    "npm",
    "security",
    "dependency-analysis"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/jadsongmatos/ctest/issues"
  },
  "homepage": "https://github.com/jadsongmatos/ctest#readme",
  "dependencies": {
    "@cyclonedx/cyclonedx-npm": "^4.2.0",
    "@prisma/client": "^6.19.2",
    "prisma": "^6.19.2"
  },
  "devDependencies": {
    "jest": "^30.2.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  }
}
