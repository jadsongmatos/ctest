{
  "name": "ctest",
  "version": "2.0.0",
  "description": "Gera arquivos .md com testes externos relevantes usando SBOM + Horsebox.",
  "main": "src/index.js",
  "bin": {
    "ctest": "./src/index.js"
  },
  "scripts": {
    "ctest": "node src/index.js",
    "test": "jest --coverage"
  },
  "keywords": [
    "sbom",
    "cyclonedx",
    "horsebox",
    "code-search",
    "dependency-analysis"
  ],
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@babel/parser": "^7.28.0",
    "@cyclonedx/cyclonedx-npm": "^4.2.0"
  },
  "devDependencies": {
    "jest": "^30.2.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/src_modules/"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  }
}
