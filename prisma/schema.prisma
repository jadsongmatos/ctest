generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "sqlite"
  relationMode = "prisma"
}

model Component {
  id         Int      @id @default(autoincrement())
  name       String
  version    String
  repo_url   String?
  created_at DateTime @default(now())

  @@unique([name, version])
  @@map("components")
}

model ExternalComponent {
  id           Int              @id @default(autoincrement())
  name         String
  version      String
  repo_url     String?
  downloadPath String?
  createdAt    DateTime         @default(now())

  externalTestFiles ExternalTestFile[]

  @@unique([name, version])
  @@map("external_components")
}

model ExternalTestFile {
  id              Int                @id @default(autoincrement())
  externalComponentId Int
  path            String
  externalComponent ExternalComponent  @relation(fields: [externalComponentId], references: [id], onDelete: Cascade)

  @@unique([externalComponentId, path])
  @@map("external_test_files")
}
